<UserControl
    x:Class="User.ActiveBeltTensioner.DeviceControl"
    x:Name="Interface"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:converter="http://metro.mahapps.com/winfx/xaml/iconpacks"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:iconpacks="clr-namespace:MahApps.Metro.IconPacks;assembly=MahApps.Metro.IconPacks.Material"
    xmlns:local="clr-namespace:User.ActiveBeltTensioner"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:styles="clr-namespace:SimHub.Plugins.Styles;assembly=SimHub.Plugins"
    xmlns:ui="clr-namespace:SimHub.Plugins.UI;assembly=SimHub.Plugins"
    xmlns:oxy="http://oxyplot.org/wpf"
    d:DataContext="{d:DesignInstance Type=local:DeviceViewModel}"
    mc:Ignorable="d"
>
    <ScrollViewer>
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition />
                <ColumnDefinition Width="0*" />
            </Grid.ColumnDefinitions>

            <StackPanel>

                <styles:SHTabControl>
                    <styles:SHTabItem Header="Connection">
                        <styles:SHTitledGroup Title="Status &amp; Setup">
                            <StackPanel>

                                <StackPanel>
                                    <TextBlock TextWrapping="WrapWithOverflow" Margin="0,0,0,20">
                                            <Label Content="Enable Motors" Margin="-5,0,0,0" />
                                            <styles:SHToggleCheckbox IsChecked="{Binding Settings.IsEnabled, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" IsEnabled="{Binding Settings.IsSerialPortValid}" />
                                            <Label Content="Start Automatically" Margin="-5,0,0,0" />
                                            <styles:SHToggleCheckbox IsChecked="{Binding Settings.StartAutomatically, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                                            <Label Content="Flip Channels" Margin="-5,0,0,0" />
                                            <styles:SHToggleCheckbox IsChecked="{Binding Settings.IsFlipped, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                                    </TextBlock>
                                </StackPanel>

                                <Grid>

                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition />
                                        <ColumnDefinition />
                                    </Grid.ColumnDefinitions>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="600" />
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" />
                                    </Grid.RowDefinitions>

                                    <Image Grid.Column="0" Grid.Row="0" Source="{Binding MotorController.LeftMotorGraphic}" HorizontalAlignment="Right" RenderTransformOrigin="0.5,0.5">
                                        <Image.RenderTransform>
                                            <ScaleTransform ScaleX="1"/>
                                        </Image.RenderTransform>
                                    </Image>
                                    <Image Grid.Column="1" Grid.Row="0" Source="{Binding MotorController.RightMotorGraphic}" HorizontalAlignment="Left" RenderTransformOrigin="0.5,0.5">
                                        <Image.RenderTransform>
                                            <ScaleTransform ScaleX="-1"/>
                                        </Image.RenderTransform>
                                    </Image>

                                    <Image Grid.Column="0" Grid.Row="0" Grid.ColumnSpan="2" Source="/User.ActiveBeltTensioner;component/SABT Logo.png" Width="150" Margin="0,0,0,460"/>

                                    <styles:SHButtonPrimary Grid.Column="0" Grid.Row="2" HorizontalAlignment="Stretch" Click="TestLeftMotor" Margin="0,0,10,0" IsEnabled="{Binding MotorController.LeftMotorIsConnected}">Test Motor</styles:SHButtonPrimary>
                                    <styles:SHButtonPrimary Grid.Column="1" Grid.Row="2" HorizontalAlignment="Stretch" Click="TestRightMotor" Margin="10,0,0,0" IsEnabled="{Binding MotorController.RightMotorIsConnected}">Test Motor</styles:SHButtonPrimary>

                                    <TextBox Grid.Column="0" Grid.Row="3" Text="{Binding MotorController.LeftMotorStatus, Mode=OneWay}" Margin="1,15,10,0" IsReadOnly="True" IsEnabled="False" VerticalAlignment="Stretch" HorizontalAlignment="Stretch" VerticalContentAlignment="Center" HorizontalContentAlignment="Center" />
                                    <TextBox Grid.Column="1" Grid.Row="3" Text="{Binding MotorController.RightMotorStatus, Mode=OneWay}" Margin="11,15,0,0" IsReadOnly="True" IsEnabled="False" VerticalAlignment="Stretch" HorizontalAlignment="Stretch" VerticalContentAlignment="Center" HorizontalContentAlignment="Center" />

                                    <TextBlock Grid.Column="0" Grid.Row="4" Grid.ColumnSpan="2" TextWrapping="WrapWithOverflow" Margin="2,50,2,20">
                                        Select a serial port from the drop-down list below. Only ports that appear to be the belt tensioner device will be shown. If the list is empty, check that the controller is plugged in. It should appear even without power or any motors connected.
                                        <LineBreak />
                                        <LineBreak />
                                        Future launches of SimHub should remember your port selection and reconnect automatically. However the 'Enable Motors' option will be reset every launch unless 'Start Automatically' is also enabled.
                                        <LineBreak />
                                        <LineBreak />
                                        If this is your first time setting up, you'll need to then click 'Setup Motors' and follow the instructions given. You'll only need to do this once, as each motor stores its configuration once set.
                                    </TextBlock>

                                    <ComboBox Grid.Column="0" Grid.Row="5" Grid.ColumnSpan="2" ItemsSource="{Binding MotorController.SerialPorts}" SelectedItem="{Binding Settings.SerialPort, UpdateSourceTrigger=PropertyChanged}" Margin="-1,10,-1,10" />

                                    <styles:SHButtonPrimary Grid.Column="0" Grid.Row="6" Grid.ColumnSpan="2" HorizontalAlignment="Stretch" Click="SetupMotors" Margin="0,0,0,0" IsEnabled="{Binding Settings.IsSerialPortValid}">Setup Motors</styles:SHButtonPrimary>

                                </Grid>

                            </StackPanel>
                        </styles:SHTitledGroup>
                    </styles:SHTabItem>
                    <styles:SHTabItem Header="Tension">
                        <styles:SHTitledGroup Title="Belt Tension Adjustment">
                            <StackPanel>

                                <ui:TitledSlider Title="Idle Tension" Maximum="250" Minimum="0" Value="{Binding Settings.IdleTension, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                                <Label Content="• Always applied while not driving (no effect while driving)" />
                                <Label Content="• Behaves like the retraction spring on an interia reel belt" />
                                <Label Content="• Set to zero to disable; limited to 25% of maximum motor torque" />

                                <styles:SHSectionSeparator />

                                <ui:TitledRangeSlider Title="Driving Tension" Maximum="1000" Minimum="0" LowerValue="{Binding Settings.MinimumTension, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" UpperValue="{Binding Settings.MaximumTension, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                                <Label Content="• The minimum and maximum tension to be applied while driving" />
                                <Label Content="• Increasing the minimum will apply a constant tension and enhance acceleration and jumping effects" />
                                <Label Content="• Reducing the maximum will result in a reduction of overall tension strength" />

                                <styles:SHSectionSeparator />

                                <ui:TitledSlider Title="Left/Right Bias" Maximum="1000" Minimum="-1000" Value="{Binding Settings.SideBias, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                                <Label Content="• If tension feels unbalanced between sides, adjust this left or right to bias towards that side" />
                                <Label Content="• Check and correct your belt path and contact points before resorting to using this setting" />

                            </StackPanel>
                        </styles:SHTitledGroup>
                    </styles:SHTabItem>
                    <styles:SHTabItem Header="Effects">
                        <styles:SHTitledGroup Title="Effect Strength Adjustment">
                            <StackPanel>

                                <ui:TitledSlider Title="Cornering" Maximum="1000" Minimum="0" Value="{Binding Settings.CorneringStrength, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                                <Label Content="• How much cornering forces should affect the tension differential between the two belts" />

                                <styles:SHSectionSeparator />

                                <ui:TitledSlider Title="Braking" Maximum="1000" Minimum="0" Value="{Binding Settings.BrakingStrength, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                                <Label Content="• How much decceleration forces should increase the tension on both belts" />

                                <styles:SHSectionSeparator />

                                <ui:TitledSlider Title="Acceleration" Maximum="1000" Minimum="0" Value="{Binding Settings.AccelerationStrength, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                                <!-- IsEnabled="{Binding IsMinimumTensionNonZero}" -->
                                <Label Content="• How much acceleration forces should decrease the tension on both belts" />
                                <Label Content="• Set minimum 'Driving Tension' to non-zero for best results (see 'Tension' tab)" />

                                <styles:SHSectionSeparator />

                                <ui:TitledSlider Title="Jumping" Maximum="1000" Minimum="0" Value="{Binding Settings.JumpingStrength, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                                <!-- IsEnabled="{Binding IsMinimumTensionNonZero}" -->
                                <Label Content="• How much jumping should decrease the tension on both belts" />
                                <Label Content="• Set minimum 'Driving Tension' to non-zero for best results (see 'Tension' tab)" />

                                <styles:SHSectionSeparator />

                                <ui:TitledSlider Title="Landing" Maximum="1000" Minimum="0" Value="{Binding Settings.LandingStrength, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                                <Label Content="• How much landing should increase the tension on both belts" />

                                <styles:SHSectionSeparator />
                                <ui:TitledSlider Title="Shifting" Maximum="1000" Minimum="0" Value="{Binding Settings.ShiftingStrength, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                                <Label Content="• Adds a more pronounced release of tension on upshift than standard telemetry offers" />
                                <Label Content="• Set minimum 'Driving Tension' to non-zero for best results (see 'Tension' tab)" />

                            </StackPanel>
                        </styles:SHTitledGroup>
                    </styles:SHTabItem>
                    <styles:SHTabItem Header="Tuning">
                        <styles:SHTitledGroup Title="Telemetry Handling">
                            <StackPanel>

                                <oxy:PlotView Height="600" HorizontalAlignment="Stretch" Margin="-14,-10,-14,15" Background="#202020" Model="{Binding TelemetryGraphModel}" />

                                <ui:TitledRangeSlider Title="Surge Limits (Acceleration/Braking)" Maximum="50" Minimum="-50" LowerValue="{Binding Settings.MinimumSurge, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" UpperValue="{Binding Settings.MaximumSurge, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                                <ui:TitledRangeSlider Title="Sway Limits (Cornering)" Maximum="50" Minimum="-50" LowerValue="{Binding Settings.MinimumSway, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" UpperValue="{Binding Settings.MaximumSway, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                                <ui:TitledRangeSlider Title="Heave Limits (Jumps)" Maximum="100" Minimum="-50" LowerValue="{Binding Settings.MinimumHeave, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" UpperValue="{Binding Settings.MaximumHeave, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />

                                <Label Content="• The permitted value ranges for incoming telemetry (anything more or less will be clipped)" />
                                <Label Content="• Set appropriately for the types of vehicles you mostly drive (defaults are fine for most)" />
                                <Label Content="• Narrower ranges result in more aggressive effects, wider ranges result in greater subtlety" />
                                <Label Content="• Run a replay to see live telemetry plotted above and to make adjustment easier" />

                                <styles:SHSectionSeparator />

                                <ui:TitledSlider Title="Smoothing Factor" Maximum="750" Minimum="0" Value="{Binding Settings.SmoothingFactor, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                                <Label Content="• How much the tension output should be smoothed" />

                            </StackPanel>
                        </styles:SHTitledGroup>
                    </styles:SHTabItem>
                    <styles:SHTabItem Header="Credits">
                        <styles:SHTitledGroup Title="Licensing &amp; Author Information">
                            <StackPanel>

                                <TextBlock TextWrapping="WrapWithOverflow" Margin="10">
                                    <Image Source="/User.ActiveBeltTensioner;component/GW Logo.png" Width="105" Margin="-3,0,0,8"/>
                                    <LineBreak />
                                    Hardware and software design by George Wilkins:
                                    <LineBreak />
                                    <Hyperlink NavigateUri="https://georgewilkins.co.uk" Click="OpenHyperlink">Website</Hyperlink>
                                    <LineBreak />
                                    <Hyperlink NavigateUri="mailto:sabt@georgewilkins.co.uk" Click="OpenHyperlink">E-Mail</Hyperlink>
                                    <LineBreak />
                                    <Hyperlink NavigateUri="https://github.com/GeorgeWilkins" Click="OpenHyperlink">GitHub Profile</Hyperlink>
                                    <LineBreak />
                                    <Hyperlink NavigateUri="https://github.com/GeorgeWilkins/Simple-Active-Belt-Tensioner/blob/main/LICENSE.md" Click="OpenHyperlink">Project License</Hyperlink>
                                    <LineBreak />
                                    <LineBreak />
                                    SimHub plugin based upon 'SimHub Plugin Demo' by SHWotever:
                                    <LineBreak />
                                    <Hyperlink NavigateUri="https://github.com/SHWotever/SimHub/wiki/Plugin-and-extensions-SDKs" Click="OpenHyperlink">SDK Documentation</Hyperlink>
                                    <LineBreak />
                                    <Hyperlink NavigateUri="https://github.com/SHWotever" Click="OpenHyperlink">GitHub Profile</Hyperlink>
                                    <LineBreak />
                                    <LineBreak />
                                    Pre-Release Testing &amp; Feedback by TurtleMenace:
                                    <LineBreak />
                                    <Hyperlink NavigateUri="https://github.com/turtlemenace" Click="OpenHyperlink">GitHub Profile</Hyperlink>
                                    <LineBreak />
                                    <LineBreak />
                                    <iconpacks:PackIconMaterial Grid.Column="0" Width="25" Height="25" Margin="0,0,0,8" Kind="GithubBox" />
                                    <LineBreak />
                                    For more information, to report a bug or contribute, consult the project GitHub repository:
                                    <LineBreak />
                                    <Hyperlink NavigateUri="https://github.com/GeorgeWilkins/Simple-Active-Belt-Tensioner" Click="OpenHyperlink">GitHub Repository</Hyperlink>
                                </TextBlock>

                            </StackPanel>
                        </styles:SHTitledGroup>
                    </styles:SHTabItem>
                </styles:SHTabControl>


            </StackPanel>
        </Grid>
    </ScrollViewer>
</UserControl>