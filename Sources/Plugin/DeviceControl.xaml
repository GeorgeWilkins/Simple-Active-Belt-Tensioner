<UserControl
    x:Class="User.ActiveBeltTensioner.DeviceControl"
    x:Name="Interface"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:converter="http://metro.mahapps.com/winfx/xaml/iconpacks"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:iconpacks="clr-namespace:MahApps.Metro.IconPacks;assembly=MahApps.Metro.IconPacks.Material"
    xmlns:local="clr-namespace:User.ActiveBeltTensioner"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:styles="clr-namespace:SimHub.Plugins.Styles;assembly=SimHub.Plugins"
    xmlns:ui="clr-namespace:SimHub.Plugins.UI;assembly=SimHub.Plugins"
    xmlns:oxy="http://oxyplot.org/wpf"
    d:DataContext="{d:DesignInstance Type=local:DeviceViewModel}"
    mc:Ignorable="d"
>
    <ScrollViewer>
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition />
                <ColumnDefinition Width="0*" />
            </Grid.ColumnDefinitions>

            <StackPanel>

                <styles:SHTabControl>
                    <styles:SHTabItem Header="Connection">
                        <styles:SHTitledGroup Title="Motor Status">
                            <StackPanel>

                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="2*" />
                                        <ColumnDefinition Width="3*" />
                                        <ColumnDefinition Width="2*" />
                                    </Grid.ColumnDefinitions>
                                    <Grid.RowDefinitions>
                                        <RowDefinition />
                                        <RowDefinition Height="70" />
                                        <RowDefinition />
                                        <RowDefinition />
                                        <RowDefinition />
                                    </Grid.RowDefinitions>

                                    <Image Grid.Column="0" Grid.Row="0" Source="/User.ActiveBeltTensioner;component/Channel.png" HorizontalAlignment="Center" RenderTransformOrigin="0.5,0.5">
                                        <Image.RenderTransform>
                                            <ScaleTransform ScaleX="1"/>
                                        </Image.RenderTransform>
                                    </Image>
                                    <StackPanel Grid.Column="1" Grid.Row="0">
                                        <TextBlock TextWrapping="WrapWithOverflow" Margin="10">
                                            If this is the first time setting up your tensioner (or you are replacing a motor), you'll need to set which channel each motor belongs to.
                                            <LineBreak /><LineBreak />
                                            This is done by connecting a single motor at a time and clicking on 'Set Channel'. This saves a numeric identifier to the motor, which this plugin then addresses commands to.
                                            <LineBreak /><LineBreak />
                                            Once that's done for both motors you can plug them both back in and they should be automatically detected.
                                            <LineBreak /><LineBreak />
                                            Note that a motor can only be assigned an identifier/channel once per power cycle; you'll have to disconnect the motor and reconnect it if you've set the wrong one. This is an intentional limitation of the motor controller.
                                            <LineBreak /><LineBreak />
                                            <Label Content="Enable Plugin" Margin="-5,0,0,0" />
                                            <styles:SHToggleCheckbox IsChecked="{Binding Settings.IsEnabled, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                                            <Label Content="Flip Channels" Margin="-5,0,0,0" />
                                            <styles:SHToggleCheckbox IsChecked="{Binding Settings.IsFlipped, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                                        </TextBlock>

                                    </StackPanel>
                                    <Image Grid.Column="2" Grid.Row="0" Source="/User.ActiveBeltTensioner;component/Channel.png" HorizontalAlignment="Center" RenderTransformOrigin="0.5,0.5">
                                        <Image.RenderTransform>
                                            <ScaleTransform ScaleX="-1"/>
                                        </Image.RenderTransform>
                                    </Image>

                                    <iconpacks:PackIconMaterial Grid.Column="0" Grid.Row="1" Width="50" Height="50"  Kind="{Binding MotorController.LeftMotorIcon}" VerticalAlignment="Center" HorizontalAlignment="Center" />
                                    <iconpacks:PackIconMaterial Grid.Column="2" Grid.Row="1" Width="50" Height="50" Kind="{Binding MotorController.RightMotorIcon}" VerticalAlignment="Center" HorizontalAlignment="Center" />

                                    <ComboBox Grid.Column="1" Grid.Row="3" ItemsSource="{Binding MotorController.SerialPorts}" SelectedItem="{Binding Settings.SerialPort, UpdateSourceTrigger=PropertyChanged}" Margin="35,10,35,0" />

                                    <styles:SHButtonPrimary Grid.Column="1" Grid.Row="2" HorizontalAlignment="Stretch" Click="RefreshSerialPorts" Margin="35,10,35,0">Refresh Serial Ports</styles:SHButtonPrimary>

                                    <styles:SHButtonPrimary Grid.Column="0" Grid.Row="2" HorizontalAlignment="Stretch" Click="SetLeftMotorIdentifier" Margin="0,10,0,0" IsEnabled="{Binding MotorController.OneMotorIsConnected}">Set Channel</styles:SHButtonPrimary>
                                    <styles:SHButtonPrimary Grid.Column="2" Grid.Row="2" HorizontalAlignment="Stretch" Click="SetRightMotorIdentifier" Margin="0,10,0,0" IsEnabled="{Binding MotorController.OneMotorIsConnected}">Set Channel</styles:SHButtonPrimary>

                                    <styles:SHButtonPrimary Grid.Column="0" Grid.Row="3" HorizontalAlignment="Stretch" Click="TestLeftMotor" Margin="0,10,0,0" IsEnabled="{Binding MotorController.LeftMotorIsConnected}">Test Motor</styles:SHButtonPrimary>
                                    <styles:SHButtonPrimary Grid.Column="2" Grid.Row="3" HorizontalAlignment="Stretch" Click="TestRightMotor" Margin="0,10,0,0" IsEnabled="{Binding MotorController.RightMotorIsConnected}">Test Motor</styles:SHButtonPrimary>

                                    <TextBox Grid.Column="0" Grid.Row="4" Text="{Binding MotorController.LeftMotorStatus, Mode=OneWay}" Margin="1,12,0,10" IsReadOnly="True" IsEnabled="False" VerticalAlignment="Stretch" HorizontalAlignment="Stretch" VerticalContentAlignment="Center" HorizontalContentAlignment="Center" />
                                    <TextBox Grid.Column="2" Grid.Row="4" Text="{Binding MotorController.RightMotorStatus, Mode=OneWay}" Margin="1,12,0,10" IsReadOnly="True" IsEnabled="False" VerticalAlignment="Stretch" HorizontalAlignment="Stretch" VerticalContentAlignment="Center" HorizontalContentAlignment="Center" />
                                </Grid>

                            </StackPanel>
                        </styles:SHTitledGroup>
                    </styles:SHTabItem>
                    <styles:SHTabItem Header="Tension">
                        <styles:SHTitledGroup Title="Belt Tension Adjustment">
                            <StackPanel>

                                <ui:TitledSlider Title="Idle Tension" Maximum="250" Minimum="0" Value="{Binding Settings.IdleTension, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                                <Label Content="• Always applied while not driving (no effect while driving)" />
                                <Label Content="• Behaves like the retraction spring on an interia reel belt" />
                                <Label Content="• Set to zero to disable; limited to 25% of maximum motor torque" />

                                <styles:SHSectionSeparator />

                                <ui:TitledRangeSlider Title="Driving Tension" Maximum="1000" Minimum="0" LowerValue="{Binding Settings.MinimumTension, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" UpperValue="{Binding Settings.MaximumTension, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                                <Label Content="• The minimum and maximum tension to be applied while driving" />
                                <Label Content="• Increasing the minimum will apply a constant tension and enhance acceleration and jumping effects" />
                                <Label Content="• Reducing the maximum will result in a reduction of overall tension strength" />

                                <styles:SHSectionSeparator />

                                <ui:TitledSlider Title="Left/Right Bias" Maximum="1000" Minimum="-1000" Value="{Binding Settings.SideBias, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                                <Label Content="• If tension feels unbalanced between sides, adjust this left or right to bias towards that side" />
                                <Label Content="• Check and correct your belt path and contact points before resorting to using this setting" />

                            </StackPanel>
                        </styles:SHTitledGroup>
                    </styles:SHTabItem>
                    <styles:SHTabItem Header="Effects">
                        <styles:SHTitledGroup Title="Effect Strength Adjustment">
                            <StackPanel>

                                <ui:TitledSlider Title="Cornering" Maximum="1000" Minimum="0" Value="{Binding Settings.CorneringStrength, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                                <Label Content="• How much cornering forces should affect the tension differential between the two belts" />

                                <styles:SHSectionSeparator />

                                <ui:TitledSlider Title="Braking" Maximum="1000" Minimum="0" Value="{Binding Settings.BrakingStrength, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                                <Label Content="• How much decceleration forces should increase the tension on both belts" />

                                <styles:SHSectionSeparator />

                                <ui:TitledSlider Title="Acceleration" Maximum="1000" Minimum="0" Value="{Binding Settings.AccelerationStrength, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                                <!-- IsEnabled="{Binding IsMinimumTensionNonZero}" -->
                                <Label Content="• How much acceleration forces should decrease the tension on both belts" />
                                <Label Content="• Set minimum 'Driving Tension' to non-zero for best results (see 'Tension' tab)" />

                                <styles:SHSectionSeparator />

                                <ui:TitledSlider Title="Jumping" Maximum="1000" Minimum="0" Value="{Binding Settings.JumpingStrength, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                                <!-- IsEnabled="{Binding IsMinimumTensionNonZero}" -->
                                <Label Content="• How much jumping should decrease the tension on both belts" />
                                <Label Content="• Set minimum 'Driving Tension' to non-zero for best results (see 'Tension' tab)" />

                                <styles:SHSectionSeparator />

                                <ui:TitledSlider Title="Landing" Maximum="1000" Minimum="0" Value="{Binding Settings.LandingStrength, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                                <Label Content="• How much landing should increase the tension on both belts" />

                                <styles:SHSectionSeparator />
                                <ui:TitledSlider Title="Shifting" Maximum="1000" Minimum="0" Value="{Binding Settings.ShiftingStrength, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                                <Label Content="• Adds a more pronounced release of tension on upshift than standard telemetry offers" />
                                <Label Content="• Requires 'Tension' > 'Idle Tension' to be greater than zero" />

                            </StackPanel>
                        </styles:SHTitledGroup>
                    </styles:SHTabItem>
                    <styles:SHTabItem Header="Tuning">
                        <styles:SHTitledGroup Title="Telemetry Handling">
                            <StackPanel>

                                <oxy:PlotView Height="600" HorizontalAlignment="Stretch" Margin="-10,0,-2,25" Background="Transparent" Model="{Binding TelemetryGraphModel}" />

                                <ui:TitledRangeSlider Title="Surge Limits (Acceleration/Braking)" Maximum="50" Minimum="-50" LowerValue="{Binding Settings.MinimumSurge, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" UpperValue="{Binding Settings.MaximumSurge, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                                <ui:TitledRangeSlider Title="Sway Limits (Cornering)" Maximum="50" Minimum="-50" LowerValue="{Binding Settings.MinimumSway, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" UpperValue="{Binding Settings.MaximumSway, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                                <ui:TitledRangeSlider Title="Heave Limits (Jumps)" Maximum="100" Minimum="-50" LowerValue="{Binding Settings.MinimumHeave, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" UpperValue="{Binding Settings.MaximumHeave, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />

                                <Label Content="• The permitted value ranges for incoming telemetry (anything more or less will be clipped)" />
                                <Label Content="• Set appropriately for the types of vehicles you mostly drive (defaults are fine for most)" />
                                <Label Content="• Run a replay to see live telemetry plotted above and to make adjustment easier" />

                                <styles:SHSectionSeparator />

                                <ui:TitledSlider Title="Smoothing Factor" Maximum="750" Minimum="0" Value="{Binding Settings.SmoothingFactor, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                                <Label Content="• How much the tension output should be smoothed" />

                            </StackPanel>
                        </styles:SHTitledGroup>
                    </styles:SHTabItem>
                    <styles:SHTabItem Header="Credits">
                        <styles:SHTitledGroup Title="Licensing &amp; Author Information">
                            <StackPanel>

                                <TextBlock TextWrapping="WrapWithOverflow" Margin="10">
                                    'Simple Active Belt Tensioner' hardware and software design by George Wilkins:
                                    <LineBreak />
                                    <Hyperlink NavigateUri="https://georgewilkins.co.uk" Click="OpenHyperlink">georgewilkins.co.uk</Hyperlink>
                                    <LineBreak />
                                    <Hyperlink NavigateUri="mailto:sabt@georgewilkins.co.uk" Click="OpenHyperlink">sabt@georgewilkins.co.uk</Hyperlink>
                                    <LineBreak />
                                    <Hyperlink NavigateUri="https://github.com/GeorgeWilkins" Click="OpenHyperlink">https://github.com/GeorgeWilkins</Hyperlink>
                                    <LineBreak />
                                    <LineBreak />
                                    SimHub plugin based upon 'SimHub Plugin Demo' by SHWotever:
                                    <LineBreak />
                                    <Hyperlink NavigateUri="https://github.com/SHWotever/SimHub/wiki/Plugin-and-extensions-SDKs" Click="OpenHyperlink">https://github.com/SHWotever/SimHub/wiki/Plugin-and-extensions-SDKs</Hyperlink>
                                    <LineBreak />
                                    <Hyperlink NavigateUri="https://github.com/SHWotever" Click="OpenHyperlink">https://github.com/SHWotever</Hyperlink>
                                    <LineBreak />
                                    <LineBreak />
                                    Pre-Release Testing &amp; Feedback by TurtleMenace:
                                    <LineBreak />
                                    <Hyperlink NavigateUri="https://github.com/turtlemenace" Click="OpenHyperlink">https://github.com/turtlemenace</Hyperlink>
                                    <LineBreak />
                                    <LineBreak />
                                    <LineBreak />
                                    <LineBreak />
                                    <iconpacks:PackIconMaterial Grid.Column="0" Width="25" Height="25" Kind="GithubBox" />
                                    <LineBreak />
                                    For more information, to report a bug or contribute, consult the project GitHub repository:
                                    <LineBreak />
                                    <Hyperlink NavigateUri="https://github.com/GeorgeWilkins/Simple-Active-Belt-Tensioner" Click="OpenHyperlink">https://github.com/GeorgeWilkins/Simple-Active-Belt-Tensioner</Hyperlink>
                                </TextBlock>

                            </StackPanel>
                        </styles:SHTitledGroup>
                    </styles:SHTabItem>
                </styles:SHTabControl>


            </StackPanel>
        </Grid>
    </ScrollViewer>
</UserControl>